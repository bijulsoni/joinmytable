# =====================================================================
# JoinMyTable - environment variable template
# =====================================================================
# Copy to `.env.local` for local dev. NEVER commit a real .env file.
# All keys an agent might need are listed here; fill in only what your
# slice requires. Vars prefixed with NEXT_PUBLIC_ are exposed to the
# browser - keep secrets out of that namespace.
# =====================================================================

# ---- Application -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# One of: development | staging | production. Used in logs + Sentry tags.
APP_ENV=development

# ---- Supabase (Foundations + Database + Auth + Core API) -------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# For local migrations / type generation.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# ---- Stripe (Payments agent) -----------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Connect platform account id.
STRIPE_CONNECT_CLIENT_ID=

# ---- Maps (Integrations agent) ---------------------------------------
# Choose one provider; the maps module wraps the difference.
NEXT_PUBLIC_MAPS_PROVIDER=google
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side geocoding key (no referrer restriction).
GOOGLE_MAPS_SERVER_API_KEY=
# Alternative provider.
NEXT_PUBLIC_MAPBOX_PUBLIC_TOKEN=
MAPBOX_SECRET_TOKEN=

# ---- Email (Integrations agent) --------------------------------------
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=hello@joinmytable.example
EMAIL_REPLY_TO_ADDRESS=support@joinmytable.example

# ---- Observability (Foundations agent) -------------------------------
# Public DSN is fine to expose; auth token is for source-map upload only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
